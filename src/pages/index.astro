---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/sections/Hero.astro';
import AboutBusiness from '../components/sections/AboutBusiness.astro';
import CompanyAbout from '../components/sections/CompanyAbout.astro';
import Services from '../components/sections/Services.astro';
import Projects from '../components/sections/Projects.astro';
import Benefits from '../components/sections/Benefits.astro';
import CTA from '../components/sections/CTA.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import { type Language } from '../i18n/i18n';

// Obtener idioma de la URL o usar español por defecto
const lang: Language = (Astro.url.searchParams.get('lang') as Language) || 'es';
---

<Layout title="Repanica SL - Alquiler de Plantas Móviles">
  <Header />
  <Hero lang={lang} />
  <AboutBusiness />
  <CompanyAbout />
  <Services />
  <Projects />
  <Benefits />
  <CTA />
  <Footer />
  <WhatsAppButton />

  <script>
    // Importar GSAP y plugins necesarios
    import gsap from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    import { ScrollToPlugin } from 'gsap/ScrollToPlugin';

    gsap.registerPlugin(ScrollTrigger, ScrollToPlugin);

    // Función unificada que inicializa todas las animaciones del sitio
    const initAllAnimations = () => {
      // 1. Animaciones de scroll para secciones
      const sections = document.querySelectorAll('.about-business, .company-about, .services, .projects, .benefits, .cta');
      
      sections.forEach((section) => {
        gsap.fromTo(
          section,
          {
            opacity: 0,
            y: 30,
          },
          {
            opacity: 1,
            y: 0,
            duration: 0.8,
            scrollTrigger: {
              trigger: section,
              start: 'top 80%',
              end: 'top 20%',
              toggleActions: 'play none none none',
            },
          }
        );
      });

      // 2. Animaciones cinemáticas para cada artículo de la sección about-business
      const articles = document.querySelectorAll('.business-article');
      articles.forEach((article) => {
        const content = article.querySelector('.article-content');
        const image = article.querySelector('.article-image');
        const isAlternate = article.classList.contains('article-2');
        
        const tl = gsap.timeline({
          scrollTrigger: {
            trigger: article,
            start: 'top 65%', /* Se activa más tarde, cuando el artículo está bien centrado en el viewport */
            toggleActions: 'play none none none'
          }
        });

        // Configuración inicial de opacidad cero mediante GSAP para evitar parpadeos en CSS
        gsap.set(article, { opacity: 0 });
        if (content) gsap.set(content, { opacity: 0 });
        if (image) gsap.set(image, { opacity: 0 });

        tl.fromTo(article, 
          { opacity: 0, y: 50 }, 
          { opacity: 1, y: 0, duration: 1.2, ease: 'power2.out' } /* Duración ampliada para revelado lento */
        );

        if (content && image) {
          tl.fromTo(content,
            { opacity: 0, x: isAlternate ? 50 : -50 },
            { opacity: 1, x: 0, duration: 1.5, ease: 'power3.out' }, /* Deslizamientos mucho más pausados y fluidos */
            '-=0.9'
          ).fromTo(image,
            { opacity: 0, x: isAlternate ? -50 : 50 },
            { opacity: 1, x: 0, duration: 1.5, ease: 'power3.out' }, /* Deslizamiento lento síncrono */
            '-=1.5'
          );
        }
      });

      // 3. Animación progresiva de aumento de números (Counter Up) para las estadísticas
      const counters = document.querySelectorAll('.count');
      counters.forEach((counter) => {
        const targetVal = parseInt(counter.getAttribute('data-target') || '0', 10);
        const countObj = { value: 0 };
        
        gsap.to(countObj, {
          value: targetVal,
          duration: 2.0, /* Duración de 2 segundos para un incremento suave y visible */
          ease: 'power1.out',
          scrollTrigger: {
            trigger: counter,
            start: 'top 90%',
            toggleActions: 'play none none none',
          },
          onUpdate: () => {
            counter.textContent = Math.floor(countObj.value).toString();
          }
        });
      });

      // 4. Animación interactiva de las líneas divisorias (Se expanden de izquierda a derecha con el scroll)
      const dividerLines = document.querySelectorAll('.divider-line');
      dividerLines.forEach((dividerLine) => {
        // Determinar qué sección contiene esta línea divisoria
        const parentSection = dividerLine.closest('section');
        
        gsap.fromTo(dividerLine,
          { scaleX: 0 },
          {
            scaleX: 1,
            ease: 'none',
            scrollTrigger: {
              trigger: parentSection,
              start: 'bottom bottom',
              end: 'bottom 50%',
              scrub: 2.5
            }
          }
        );
      });

      // 5. Animación de los engranajes mecánicos en la sección Services (Rotan y cambian de opacidad al escrolear)
      const gearTopLeft = document.querySelector('.gear-top-left');
      if (gearTopLeft) {
        gsap.fromTo(gearTopLeft,
          { rotation: 0, opacity: 0 },
          {
            rotation: 180,
            opacity: 0.18, /* Incrementado de 0.08 a 0.18 para que se aprecie mucho más nítido */
            ease: 'none',
            scrollTrigger: {
              trigger: '.services',
              start: 'top bottom',
              end: 'top 30%',
              scrub: 1.5
            }
          }
        );
      }

      const gearBottomRight = document.querySelector('.gear-bottom-right');
      if (gearBottomRight) {
        gsap.fromTo(gearBottomRight,
          { rotation: 0, opacity: 0.18 }, /* Incrementado de 0.08 a 0.18 */
          {
            rotation: -180,
            opacity: 0,
            ease: 'none',
            scrollTrigger: {
              trigger: '.services',
              start: 'bottom 90%',
              end: 'bottom top',
              scrub: 1.5
            }
          }
        );
      }

      // 6. Animaciones para service cards
      const serviceCards = document.querySelectorAll('.service-card');
      serviceCards.forEach((card, index) => {
        gsap.fromTo(
          card,
          {
            opacity: 0,
            y: 30,
          },
          {
            opacity: 1,
            y: 0,
            duration: 0.6,
            delay: index * 0.1,
            scrollTrigger: {
              trigger: card,
              start: 'top 85%',
              toggleActions: 'play none none none',
            },
          }
        );
      });

      // 7. Animaciones para benefit items
      const benefitItems = document.querySelectorAll('.benefit-item');
      benefitItems.forEach((item, index) => {
        gsap.fromTo(
          item,
          {
            opacity: 0,
            x: -30,
          },
          {
            opacity: 1,
            x: 0,
            duration: 0.6,
            delay: index * 0.1,
            scrollTrigger: {
              trigger: item,
              start: 'top 85%',
              toggleActions: 'play none none none',
            },
          }
        );
      });

      // 8. Smooth scroll para links de navegación
      document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', (e) => {
          const href = anchor.getAttribute('href');
          if (href && href !== '#') {
            e.preventDefault();
            const target = document.querySelector(href);
            if (target) {
              gsap.to(window, {
                duration: 0.5,
                scrollTo: {
                  y: target,
                  offsetY: 80,
                },
              });
            }
          }
        });
      });
    };

    // ── Ejecución Segura en Cualquier Ciclo de Vida ───────────────────────
    
    // Iniciar inmediatamente si el DOM ya está listo (Astro difiere scripts de forma nativa)
    if (document.readyState === 'complete' || document.readyState === 'interactive') {
      initAllAnimations();
    } else {
      document.addEventListener('DOMContentLoaded', initAllAnimations);
    }

    // Soporte para Astro ViewTransitions (si se habilita en el futuro)
    document.addEventListener('astro:page-load', initAllAnimations);
  </script>
</Layout>
