---
import SplineViewer from '../SplineViewer';
---

<section class="multimedia" id="multimedia">
  <div class="multimedia-container">
    <div class="multimedia-content">
      <div class="multimedia-text">
        <h2>Visualiza Nuestras Soluciones en 3D</h2>
        <p>Explora nuestras plantas móviles en un entorno interactivo 3D. Rota, acerca y examina cada detalle de nuestros equipos.</p>
        <ul class="features-list">
          <li>Modelos 3D interactivos en tiempo real</li>
          <li>Visualización desde cualquier ángulo</li>
          <li>Especificaciones técnicas integradas</li>
          <li>Experiencia inmersiva y profesional</li>
        </ul>
      </div>
      <div class="multimedia-viewer">
        <SplineViewer 
          client:load
          sceneUrl="https://prod.spline.design/example-scene/scene"
          className="spline-viewer"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .multimedia {
    padding: 5rem 2rem;
    background-color: #ffffff;
  }

  .multimedia-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .multimedia-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .multimedia-text {
    opacity: 0;
    animation: fadeInLeft 0.8s ease-out forwards;
  }

  .multimedia-text h2 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: #1a1a1a;
  }

  .multimedia-text > p {
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }

  .features-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .features-list li {
    padding: 0.75rem 0;
    padding-left: 2rem;
    position: relative;
    font-weight: 600;
    color: #666;
    line-height: 1.6;
  }

  .features-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: #ff6b35;
    font-weight: 700;
    font-size: 1.25rem;
  }

  .multimedia-viewer {
    opacity: 0;
    animation: fadeInRight 0.8s ease-out 0.2s forwards;
    height: 500px;
    border-radius: 1rem;
    overflow: hidden;
    background: linear-gradient(135deg, #f5f5f5 0%, #e8e8e8 100%);
  }

  .spline-viewer {
    width: 100%;
    height: 100%;
  }

  @keyframes fadeInLeft {
    from {
      opacity: 0;
      transform: translateX(-30px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes fadeInRight {
    from {
      opacity: 0;
      transform: translateX(30px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @media (max-width: 768px) {
    .multimedia {
      padding: 3rem 1rem;
    }

    .multimedia-content {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .multimedia-text h2 {
      font-size: 1.75rem;
    }

    .multimedia-viewer {
      height: 300px;
    }

    .features-list li {
      padding-left: 1.75rem;
      font-size: 0.95rem;
    }
  }
</style>
