<section class="cta" id="contacto">
  <div class="cta-container">
    <div class="cta-content">
      <h2>¿Listo para transformar tu proyecto?</h2>
      <p>Contacta con nuestro equipo de expertos para encontrar la solución perfecta para tu negocio.</p>
      <a href="/contact" class="cta-button">Solicitar presupuesto</a>
    </div>
  </div>
</section>

<style>
  .cta {
    padding: 4rem 2rem;
    background: linear-gradient(135deg, var(--color-bg-dark) 0%, var(--color-bg-darker) 100%);
    color: var(--white);
  }

  .cta-container {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .cta-content {
    opacity: 0;
    animation: fadeInScale 0.8s ease-out forwards;
  }

  .cta-content h2 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .cta-content p {
    margin-bottom: 2rem;
    color: var(--color-text-on-dark);
    line-height: 1.6;
  }

  .cta-button {
    background-color: var(--btn-primary-bg);
    color: var(--btn-primary-color);
    border: none;
    padding: 1rem 2.5rem;
    border-radius: 0.5rem;
    font-size: 1.125rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .cta-button:hover {
    background-color: var(--btn-primary-hover-bg);
    transform: translateY(-3px);
    box-shadow: var(--btn-primary-shadow);
  }

  @keyframes fadeInScale {
    from {
      opacity: 0;
      transform: scale(0.95);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  @media (max-width: 768px) {
    .cta {
      padding: 2rem 1rem;
    }

    .cta-content h2 {
      font-size: 1.75rem;
    }

    .cta-content p {
      font-size: 1rem;
    }

    .cta-button {
      width: 100%;
      padding: 0.875rem 1.5rem;
    }
  }
</style>
