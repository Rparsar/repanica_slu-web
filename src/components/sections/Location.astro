<section class="location-section">
  <div class="location-container">
    <div class="location-header">
      <h2>Dónde nos encontramos</h2>
      <p>Visítanos en nuestras instalaciones en Orihuela, Alicante</p>
    </div>

    <div class="location-content">
      <div class="location-info">
        <div class="info-item">
          <h3>Dirección</h3>
          <p>Ctra. La Aparecida, Orihuela (Alicante)</p>
        </div>

        <div class="info-item">
          <h3>Teléfono</h3>
          <p><a href="tel:+34XXX">+34 XXX XXX XXX</a></p>
        </div>

        <div class="info-item">
          <h3>Email</h3>
          <p><a href="mailto:info@repanica.es">info@repanica.es</a></p>
        </div>

        <div class="info-item">
          <h3>Horario</h3>
          <p>Lunes a Viernes: 8:00 - 18:00</p>
          <p>Sábado: 9:00 - 14:00</p>
          <p>Domingo: Cerrado</p>
        </div>
      </div>

      <div class="location-map">
        <iframe src="https://www.google.com/maps/embed?pb=!1m17!1m12!1m3!1d1877.0067558044818!2d-0.9962350482998393!3d38.079401996280026!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m2!1m1!2zMzjCsDA0JzQ1LjkiTiAwwrA1OSc0My4xIlc!5e1!3m2!1ses!2ses!4v1784751843145!5m2!1ses!2ses" width="100%" height="400" style="border:0; border-radius: 0.75rem;" allowfullscreen="" loading="lazy" referrerpolicy="strict-origin-when-cross-origin"></iframe>
      </div>
    </div>
  </div>
</section>

<style>
  .location-section {
    padding: 6rem 2rem;
    background: linear-gradient(135deg, var(--gray-100) 0%, var(--gray-300) 100%);
  }

  .location-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .location-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .location-header h2 {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-heading);
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .location-header p {
    font-size: 1.1rem;
    color: var(--color-text);
    line-height: 1.6;
  }

  .location-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  .location-info {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .info-item {
    background-color: var(--color-white);
    padding: 1.5rem;
    border-radius: 0.75rem;
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
    transition: all 0.3s ease;
  }

  .info-item:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }

  .info-item h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }

  .info-item p {
    color: var(--color-text);
    line-height: 1.6;
    margin-bottom: 0.25rem;
  }

  .info-item a {
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
  }

  .info-item a:hover {
    text-decoration: underline;
    color: #ff5a1f;
  }

  .location-map {
    border-radius: 0.75rem;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }

  @media (max-width: 900px) {
    .location-content {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .location-header h2 {
      font-size: 2rem;
    }
  }

  @media (max-width: 768px) {
    .location-section {
      padding: 4rem 1rem;
    }

    .location-header h2 {
      font-size: 1.75rem;
    }

    .location-info {
      gap: 1.5rem;
    }

    .info-item {
      padding: 1rem;
    }

    .location-map iframe {
      height: 300px !important;
    }
  }
</style>
