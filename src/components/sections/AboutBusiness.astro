---
import { Image } from 'astro:assets';
import landing1 from '../../assets/landing1.jpeg';
import landing2 from '../../assets/landing2.jpeg';
import landing3 from '../../assets/landing3.jpeg';
import bgImage from '../../assets/back-section-about.png';
---

<section class="about-business" id="init-servicios" style={`--bg-image: url('${bgImage.src}')`}>
  <div class="about-container">
    <!-- Título y Subtítulo -->
    <div class="section-intro">
      <h2>Repánica SL. Cosecha los proyectos del mañana.</h2>
      <p class="subtitle">Maquinaria de extracción de áridos</p>
    </div>

    <!-- Article 1: Texto izquierda, Imagen derecha -->
    <article class="business-article article-1">
      <div class="article-content">
        <h3>Extracción de Áridos</h3>
        <p>Somos especialistas en la extracción eficiente de áridos utilizando maquinaria de última generación. Nuestros equipos móviles permiten acceder a zonas de difícil acceso, maximizando la productividad y minimizando el impacto ambiental. Con más de 50 años de experiencia, garantizamos la calidad y seguridad en cada proyecto.</p>
      </div>
      <div class="article-image">
        <Image src={landing1} alt="Extracción de Áridos" />
      </div>
    </article>

    <!-- Article 2: Imagen izquierda, Texto derecha -->
    <article class="business-article article-2">
      <div class="article-image">
        <Image src={landing2} alt="Procesamiento y Clasificación" />
      </div>
      <div class="article-content">
        <h3>Procesamiento y Clasificación</h3>
        <p>Contamos con plantas móviles de procesamiento que clasifican y procesan áridos según las especificaciones del cliente. Desde gravas hasta arenas, nuestros equipos garantizan la calidad del material final. Operamos en toda la región de Murcia, provincia de Alicante y alrededores con máxima eficiencia.</p>
      </div>
    </article>

    <!-- Article 3: Texto izquierda, Imagen derecha -->
    <article class="business-article article-3">
      <div class="article-content">
        <h3>Transporte y Logística</h3>
        <p>Ofrecemos soluciones completas de transporte y logística para tus proyectos de extracción. Nuestro equipo profesional se encarga de la planificación, ejecución y seguimiento de cada operation. Disponemos de flota propia y alianzas estratégicas para garantizar entregas puntuales y seguras.</p>
      </div>
      <div class="article-image">
        <Image src={landing3} alt="Transporte y Logística" />
      </div>
    </article>
  </div>
</section>

<style>
  .about-business {
    position: relative;
    padding: 5rem 2rem;
    background-color: var(--color-primary-dark); /* Color base naranja oscuro para el tintado */
    background-image: linear-gradient(rgba(26, 26, 26, 0.3), rgba(26, 26, 26, 0.8)), var(--bg-image);
    background-blend-mode: multiply; /* Fusión de capas para un aspecto de marca ultra nítido y contrastado */
    background-attachment: fixed;
    background-position: center;
    background-repeat: no-repeat;
    background-size: cover;
  }

  .about-container {
    max-width: 92%; /* Ensanchado del 85% al 92% para mayor amplitud */
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  .section-intro {
    margin-bottom: 4rem;
    text-align: right;
  }

  .section-intro h2 {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--white); /* Color claro para un contraste espectacular sobre el fondo fijo */
    margin-bottom: 0.5rem;
    line-height: 1.3;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3);
  }

  .subtitle {
    font-size: 1.25rem;
    color: var(--color-primary);
    font-weight: 600;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.4);
  }

  .business-article {
    display: grid;
    grid-template-columns: 60% 40%;
    gap: 0;
    align-items: stretch;
    margin-bottom: 4rem;
    overflow: hidden;
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.3);
    border-radius: 0.75rem;
  }

  /* Article 2: imagen izquierda 40%, texto derecha 60% */
  .article-2 {
    grid-template-columns: 40% 60%;
  }

  .article-2 .article-image {
    order: -1;
  }

  /* Contenido de texto - fondo oscuro */
  .article-content {
    padding: 4rem; /* Incrementado de 3rem a 4rem para un diseño editorial premium */
    background: linear-gradient(to right, #3e1a046f  0%, #3e1a0499  35%, #3e1a04d1  70%);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .article-2 .article-content{
    background: linear-gradient(to left, #3e1a046f  0%, #3e1a0499  35%, #3e1a04d1  70%);
  }

  .article-content h3 {
    color: var(--white);
    margin-bottom: 1.5rem;
  }

  .article-content p {
    color: var(--color-text-on-dark);
    line-height: 1.8;
  }

  /* Imagen con overlay oscuro y degradado de fusión */
  .article-image {
    position: relative;
    overflow: hidden;
  }

  .article-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    opacity: 0.6;
  }

  /* Tono oscuro sobre la imagen */
  .article-image::before {
    content: '';
    position: absolute;
    inset: 0;
    background-color: transparent;
    z-index: 1;
  }

  /* Degradado de fusión: article-1 y article-3 (imagen derecha → gradiente desde la izquierda) */
  .article-image::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, #3e1a04d1  0%, #3e1a0400 35%, #0000 70%);
    z-index: 2;
  }

  /* Degradado de fusión: article-2 (imagen izquierda → gradiente desde la derecha) */
  .article-2 .article-image::after {
    background: linear-gradient(to left, #3e1a04d1 0%, #3e1a0400 35%, #0000 70%);
  }

  @media (max-width: 900px) {
    .business-article,
    .article-2 {
      grid-template-columns: 1fr;
    }

    .article-2 .article-image {
      order: 0;
    }

    /* En móvil el degradado va de arriba (imagen) hacia abajo (texto) */
    .article-image::after{
      background: linear-gradient(to bottom, #3e1a04d1 0%, #3e1a0400 35%, #0000 70%);
    }

    
    .article-2 .article-image::after {
      background: linear-gradient(to top, #3e1a04d1 0%, #3e1a0400 35%, #0000 70%);
    }

    .article-image {
      min-height: 300px;
    }

    .section-intro h2 {
      font-size: 2rem;
    }
  }

  @media (max-width: 768px) {
    .about-business {
      padding: 3rem 1rem;
      background-attachment: scroll; /* Fallback de rendimiento para móviles */
    }

    .section-intro {
      text-align: left;
      margin-bottom: 2rem;
    }

    .section-intro h2 {
      font-size: 1.5rem;
    }

    .subtitle {
      font-size: 1rem;
    }

    .article-content {
      padding: 1.5rem;
    }

    .article-content h3 {
      font-size: 1.25rem;
    }

    .article-image {
      min-height: 250px;
    }

    .business-article {
      margin-bottom: 2rem;
    }
  }
</style>
