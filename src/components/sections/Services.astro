---
import { Image } from 'astro:assets';
import mechanicalGear from '../../assets/Mechanical_gear_forming_circle_2K_202607221251.png';
---

<section class="services" id="servicios">
  <!-- Engranaje superior izquierdo decorativo de fondo -->
  <div class="gear-bg gear-top-left">
    <Image src={mechanicalGear} alt="Engranaje decorativo" class="gear-img-file" />
  </div>

  <!-- Engranaje inferior derecho decorativo de fondo -->
  <div class="gear-bg gear-bottom-right">
    <Image src={mechanicalGear} alt="Engranaje decorativo" class="gear-img-file" />
  </div>

  <div class="services-container">
    <div class="section-header">
      <div class="header-content">
        <p class="section-label">Nuestros servicios</p>
        <h2>Contamos los servicios para cubrir tus necesidades</h2>
        <p class="section-description">Disponemos de maquinaria especializada para cada tipo de proyecto en extracción de áridos.</p>
      </div>
      <a href="/servicios" class="view-more-btn">Ver más</a>
    </div>

    <div class="services-grid">
      <!-- Card 1 -->
      <div class="service-card">
        <div class="service-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 2L2 7v10c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-10-5z"></path>
          </svg>
        </div>
        <h3>Extracción de Áridos</h3>
        <p>Equipos especializados para la extracción eficiente de áridos en diferentes tipos de terreno.</p>
      </div>

      <!-- Card 2 -->
      <div class="service-card">
        <div class="service-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M12 6v6l4 2"></path>
          </svg>
        </div>
        <h3>Procesamiento</h3>
        <p>Clasificación y procesamiento de áridos según especificaciones del cliente.</p>
      </div>

      <!-- Card 3 -->
      <div class="service-card">
        <div class="service-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
            <circle cx="12" cy="10" r="3"></circle>
          </svg>
        </div>
        <h3>Transporte Logístico</h3>
        <p>Soluciones completas de transporte y logística para tus proyectos.</p>
      </div>

      <!-- Card 4 -->
      <div class="service-card">
        <div class="service-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 2v20M2 12h20"></path>
            <circle cx="12" cy="12" r="10"></circle>
          </svg>
        </div>
        <h3>Asesoramiento Técnico</h3>
        <p>Expertos disponibles para ayudarte a elegir la solución más adecuada.</p>
      </div>

      <!-- Card 5 -->
      <div class="service-card">
        <div class="service-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"></path>
            <path d="M21 3v5h-5"></path>
            <path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"></path>
            <path d="M3 21v-5h5"></path>
          </svg>
        </div>
        <h3>Mantenimiento</h3>
        <p>Servicio técnico especializado para garantizar el óptimo funcionamiento.</p>
      </div>

      <!-- Card 6 -->
      <div class="service-card">
        <div class="service-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm3.5-9c.83 0 1.5-.67 1.5-1.5S16.33 8 15.5 8 14 8.67 14 9.5s.67 1.5 1.5 1.5zm-7 0c.83 0 1.5-.67 1.5-1.5S9.33 8 8.5 8 7 8.67 7 9.5 7.67 11 8.5 11zm3.5 6.5c2.33 0 4.31-1.46 5.11-3.5H6.89c.8 2.04 2.78 3.5 5.11 3.5z"></path>
          </svg>
        </div>
        <h3>Sostenibilidad</h3>
        <p>Comprometidos con prácticas sostenibles y respetuosas con el medio ambiente.</p>
      </div>
    </div>
  </div>
  <div class="divider-line"></div>
</section>

<style>
  .services {
    position: relative; /* Necesario para los engranajes absolutos de fondo */
    overflow: hidden; /* Evita que los engranajes gigantes causen scroll horizontal */
    padding: 5rem 2rem;
    background-color: var(--color-bg-page);
  }

  .divider-line {
    position: absolute;
    bottom: 0;
    left: 0;
    height: 3px;
    background-color: var(--color-primary); /* naranja corporativo */
    width: 100%;
    transform-origin: left center;
    transform: scaleX(0); /* inicia en 0 y escala con GSAP ScrollTrigger scrub */
    z-index: 10;
  }

  /* Engranajes decorativos de fondo con animación Scroll-triggered scrub */
  .gear-bg {
    position: absolute;
    pointer-events: none;
    user-select: none;
    z-index: 1; /* Por detrás del contenido */
    color: var(--color-primary);
  }

  .gear-top-left {
    top: -160px;
    left: -160px;
    width: 360px;
    height: 360px;
    opacity: 0; /* Controlado dinámicamente con GSAP (aparecerá a 0.18) */
  }

  .gear-bottom-right {
    bottom: -160px;
    right: -160px;
    width: 360px;
    height: 360px;
    opacity: 0.18; /* Inicia sutilmente visible y GSAP lo desvanece a 0 (incrementado de 0.08 a 0.18) */
  }

  .gear-bg .gear-img-file,
  .gear-bg img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: drop-shadow(0 4px 15px rgba(255, 107, 53, 0.20)); /* Sombra proyectada naranja */
  }

  .services-container {
    position: relative;
    z-index: 2; /* Por delante de los engranajes */
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 4rem;
    gap: 2rem;
  }

  .header-content {
    flex: 1;
  }

  .section-label {
    font-size: 0.9rem;
    color: var(--color-primary);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 0.5rem;
    display: block;
  }

  .section-header h2 {
    font-size: 2.25rem;
    font-weight: 700;
    color: var(--color-heading);
    margin-bottom: 1rem;
    line-height: 1.3;
  }

  .section-description {
    font-size: 1rem;
    color: var(--color-text);
    line-height: 1.6;
  }

  .view-more-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: var(--btn-primary-bg);
    color: var(--btn-primary-color);
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
    white-space: nowrap;
    height: fit-content;
  }

  .view-more-btn:hover {
    background-color: var(--btn-primary-hover-bg);
    transform: translateY(-2px);
    box-shadow: var(--btn-primary-shadow-sm);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
  }

  .service-card {
    padding: 2rem;
    background: linear-gradient(135deg, var(--gray-100) 0%, var(--gray-300) 100%);
    border-radius: 1rem;
    transition: all 0.3s ease;
    opacity: 0;
    animation: fadeInUp 0.6s ease-out forwards;
    border: 1px solid transparent;
  }

  .service-card:nth-child(1) {
    animation-delay: 0.1s;
  }

  .service-card:nth-child(2) {
    animation-delay: 0.2s;
  }

  .service-card:nth-child(3) {
    animation-delay: 0.3s;
  }

  .service-card:nth-child(4) {
    animation-delay: 0.4s;
  }

  .service-card:nth-child(5) {
    animation-delay: 0.5s;
  }

  .service-card:nth-child(6) {
    animation-delay: 0.6s;
  }

  .service-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.1);
    border-color: var(--color-primary);
  }

  .service-icon {
    width: 50px;
    height: 50px;
    margin-bottom: 1rem;
    color: var(--color-primary);
  }

  .service-icon svg {
    width: 100%;
    height: 100%;
  }

  .service-card h3 {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-heading);
    margin-bottom: 0.75rem;
  }

  .service-card p {
    font-size: 0.95rem;
    color: var(--color-text);
    line-height: 1.6;
  }

  @media (max-width: 1024px) {
    .section-header {
      flex-direction: column;
      align-items: flex-start;
    }

    .view-more-btn {
      align-self: flex-start;
    }
  }

  @media (max-width: 768px) {
    .services {
      padding: 3rem 1rem;
    }

    .section-header {
      margin-bottom: 2rem;
    }

    .section-header h2 {
      font-size: 1.75rem;
    }

    .services-grid {
      grid-template-columns: 1fr;
    }

    .service-card {
      padding: 1.5rem;
    }
  }
</style>
