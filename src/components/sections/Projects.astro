---
import { Image } from 'astro:assets';
import proj1 from '../../assets/landing1.jpeg';
import proj2 from '../../assets/landing2.jpeg';
import proj3 from '../../assets/landing3.jpeg';
import proj4 from '../../assets/escabadora.jpeg';

const projects = [
  {
    title: 'Extracción Cantera Lorca',
    year: '2025',
    image: proj1,
    desc: 'Alquiler de planta móvil de trituración para áridos calizos.'
  },
  {
    title: 'Clasificación de Gravas Orihuela',
    year: '2024',
    image: proj2,
    desc: 'Cribado de materiales con planta móvil de alta capacidad.'
  },
  {
    title: 'Obra Autovía del Mediterráneo',
    year: '2024',
    image: proj3,
    desc: 'Suministro continuo de machaqueo secundario a pie de obra.'
  },
  {
    title: 'Excavación y Desmonte Murcia',
    year: '2023',
    image: proj4,
    desc: 'Servicio de excavación pesada y preparación de terrenos.'
  }
];
---

<section class="projects" id="proyectos">
  <div class="projects-container">
    <!-- Encabezado -->
    <div class="projects-header">
      <div>
        <p class="section-label">Portafolio</p>
        <h2>Nuestros Trabajos</h2>
        <p class="intro-text">
          Conoce algunas de nuestras operaciones más destacadas en Murcia, Alicante y provincias limítrofes. Ofrecemos plantas móviles de alta fiabilidad adaptadas a la envergadura de cada proyecto.
        </p>
      </div>
    </div>

    <!-- Carrusel Horizontal -->
    <div class="projects-carousel-wrapper">
      <div class="projects-carousel" id="projectsCarousel">
        {projects.map((project) => (
          <div class="project-card">
            <div class="project-image-wrapper">
              <Image src={project.image} alt={project.title} class="project-image" />
              <div class="project-overlay">
                <div class="project-overlay-content">
                  <h3>{project.title}</h3>
                  <span class="project-year">{project.year}</span>
                </div>
              </div>
            </div>
            <div class="project-info">
              <h3>{project.title}</h3>
              <span class="project-year-label">{project.year}</span>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Controles debajo del carrusel -->
    <div class="carousel-controls">
      <button class="control-btn prev" id="projPrevBtn" aria-label="Proyecto Anterior">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M15 19l-7-7 7-7"></path>
        </svg>
      </button>
      <button class="control-btn next" id="projNextBtn" aria-label="Siguiente Proyecto">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M9 5l7 7-7 7"></path>
        </svg>
      </button>
    </div>
  </div>
</section>

<style>
  .projects {
    padding: 6rem 2rem;
    background-color: var(--color-bg-subtle);
    position: relative;
    overflow: hidden;
  }

  .projects-container {
    max-width: 1400px;
    margin: 0 auto;
  }

  /* Encabezado */
  .projects-header {
    margin-bottom: 3rem;
  }

  .section-label {
    font-size: 0.9rem;
    color: var(--color-primary);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 0.5rem;
    display: block;
  }

  .projects-header h2 {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-heading);
    margin-bottom: 1.5rem;
    line-height: 1.2;
  }

  .intro-text {
    font-size: 1rem;
    color: var(--color-text);
    line-height: 1.7;
    font-weight: 500;
    max-width: 600px;
  }

  /* Carrusel Horizontal */
  .projects-carousel-wrapper {
    width: 100%;
    overflow: hidden;
    position: relative;
    border-radius: 1rem;
    margin-bottom: 2rem;
  }

  .projects-carousel {
    display: flex;
    flex-direction: row;
    gap: 1.5rem;
    width: 100%;
    overflow-x: scroll;
    padding-bottom: 10px;
    box-sizing: border-box;
    scroll-behavior: smooth;
    scrollbar-width: none;
  }

  .projects-carousel::-webkit-scrollbar {
    display: none;
  }

  .project-card {
    display: flex;
    flex-direction: column;
    background-color: var(--color-bg-card);
    border-radius: 0.75rem;
    overflow: hidden;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05);
    flex-shrink: 0;
    width: 320px;
    height: 320px;
  }

  .project-image-wrapper {
    position: relative;
    width: 100%;
    height: 280px;
    overflow: hidden;
  }

  .project-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1);
  }

  /* Overlay de hover */
  .project-overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(255, 107, 53, 0.90);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: all 0.4s ease;
    z-index: 2;
  }

  .project-overlay-content {
    text-align: center;
    color: var(--white);
    padding: 2rem;
    transform: translateY(20px);
    transition: transform 0.4s ease;
  }

  .project-overlay-content h3 {
    font-size: 1.4rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: var(--white);
  }

  .project-year {
    font-size: 1rem;
    font-weight: 500;
    opacity: 0.9;
    display: block;
    border-top: 1px solid rgba(255, 255, 255, 0.3);
    padding-top: 0.5rem;
    width: fit-content;
    margin: 0 auto;
  }

  .project-card:hover .project-overlay {
    opacity: 1;
  }

  .project-card:hover .project-overlay-content {
    transform: translateY(0);
  }

  .project-card:hover .project-image {
    transform: scale(1.08);
  }

  /* Info debajo de la imagen */
  .project-info {
    padding: 1rem;
    background-color: var(--color-bg-card);
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .project-info h3 {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-heading);
    margin-bottom: 0.25rem;
  }

  .project-year-label {
    font-size: 0.85rem;
    color: var(--color-primary);
    font-weight: 600;
  }

  /* Controles de Carrusel */
  .carousel-controls {
    display: flex;
    gap: 1rem;
    justify-content: center;
  }

  .control-btn {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    border: 2px solid var(--color-primary);
    background-color: transparent;
    color: var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .control-btn svg {
    width: 20px;
    height: 20px;
    transition: transform 0.3s ease;
  }

  .control-btn:hover {
    background-color: var(--color-primary);
    color: var(--white);
    box-shadow: 0 5px 15px rgba(255, 107, 53, 0.25);
  }

  .control-btn.prev:hover svg {
    transform: translateX(-2px);
  }

  .control-btn.next:hover svg {
    transform: translateX(2px);
  }

  /* ── Responsive ─────────────────────────────────────── */
  @media (max-width: 900px) {
    .projects-header h2 {
      font-size: 2rem;
    }

    .intro-text {
      margin-bottom: 1.5rem;
    }

    .project-card {
      width: 280px;
      height: 280px;
    }

    .project-image-wrapper {
      height: 230px;
    }
  }

  @media (max-width: 768px) {
    .projects {
      padding: 4rem 1rem;
    }

    .projects-header h2 {
      font-size: 1.75rem;
    }

    .project-card {
      width: 240px;
      height: 240px;
    }

    .project-image-wrapper {
      height: 190px;
    }

    .carousel-controls {
      justify-content: center;
    }
  }
</style>

<script>
  const initCarousel = () => {
    const carousel = document.getElementById('projectsCarousel');
    const prevBtn = document.getElementById('projPrevBtn');
    const nextBtn = document.getElementById('projNextBtn');

    if (!carousel) return;

    // Desplazamiento mediante botones (izquierda/derecha)
    const cardWidth = 320; // Ancho fijo de cada tarjeta
    const gap = 24; // 1.5rem de gap = 24px aprox

    prevBtn?.addEventListener('click', () => {
      carousel.scrollLeft -= (cardWidth + gap);
    });

    nextBtn?.addEventListener('click', () => {
      carousel.scrollLeft += (cardWidth + gap);
    });

    // Soporte para scroll con rueda del ratón (arriba/abajo se convierte en izquierda/derecha)
    carousel.addEventListener('wheel', (e) => {
      e.preventDefault();
      const scrollAmount = e.deltaY > 0 ? (cardWidth + gap) : -(cardWidth + gap);
      carousel.scrollLeft += scrollAmount;
    }, { passive: false });
  };

  // Cargar de forma segura para soportar cargas directas y ViewTransitions
  if (document.readyState === 'complete' || document.readyState === 'interactive') {
    initCarousel();
  } else {
    document.addEventListener('DOMContentLoaded', initCarousel);
  }

  document.addEventListener('astro:page-load', initCarousel);
</script>
