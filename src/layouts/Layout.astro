---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Repanica SL - Alquiler de plantas móviles para extracción de áridos" } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/repanica_favicon.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Rokkitt:wght@600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body>
    <slot />
    <style is:global>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        font-family: 'Rokkitt', serif;
        scroll-behavior: smooth;
      }

      body {
        background-color: #ffffff;
        color: #1a1a1a;
        line-height: 1.6;
      }

      h1 {
        font-weight: 800;
      }

      h2, h3 {
        font-weight: 700;
        font-size: 2.25rem;
      }

      h4, h5, h6 {
        font-weight: 600;
        font-size: 1.35rem;
      }

      p {
        font-weight: 600;
        font-size: 1.35rem;
        color: #666;
      }

      span, a, button {
        font-weight: 600;
      }

      /* Respetar preferencia de movimiento reducido */
      @media (prefers-reduced-motion: reduce) {
        * {
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.01ms !important;
        }
      }
    </style>
  </body>
</html>
